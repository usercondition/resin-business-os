DATABASE_URL="postgresql://postgres:postgres@localhost:5432/resin_business_os?schema=public"
APP_ENV="development"
APP_URL="http://localhost:3000"
# Required in production (e.g. Railway). Min 16 characters.
AUTH_SECRET="replace-with-strong-secret"
GOOGLE_SHEETS_CLIENT_ID=""
GOOGLE_SHEETS_CLIENT_SECRET=""
N8N_WEBHOOK_SIGNING_SECRET=""
# Inbound email HMAC (must match n8n variable RESIN_EMAIL_WEBHOOK_SECRET if your workflow uses that name).
# Use any ONE of: EMAIL_INBOUND_SIGNING_SECRET, RESIN_EMAIL_WEBHOOK_SECRET (same string as n8n), or N8N_WEBHOOK_SIGNING_SECRET.
EMAIL_INBOUND_SIGNING_SECRET=""
RESIN_EMAIL_WEBHOOK_SECRET=""
N8N_EMAIL_OUTBOUND_WEBHOOK_URL=""
# Resend: when RESEND_API_KEY and RESEND_FROM are set, the app sends reply/forward/magic-link mail via Resend (no n8n required for those).
RESEND_API_KEY=""
RESEND_FROM=""
# Svix signing secret from Resend → Webhooks → your endpoint (for POST /api/webhooks/resend, event email.received).
RESEND_WEBHOOK_SECRET=""
MESSENGER_WEBHOOK_SIGNING_SECRET=""
NEW_REQUEST_NOTIFICATION_WEBHOOK_URL=""
RATE_LIMIT_REDIS_URL=""
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
