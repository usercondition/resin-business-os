generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  STAFF
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  QUOTED
  WON
  LOST
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  DECLINED
  EXPIRED
}

enum OrderStatus {
  NEW
  CONFIRMED
  IN_PRODUCTION
  READY
  DELIVERED
  CLOSED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
}

enum ProductionStatus {
  QUEUED
  PRINTING
  POST_PROCESSING
  QA
  COMPLETE
  FAILED
}

enum DeliveryType {
  PICKUP
  DELIVERY
}

enum DeliveryStatus {
  SCHEDULED
  IN_TRANSIT
  READY_FOR_PICKUP
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH_APP
  VENMO
  ZELLE
}

enum PortalMessageAuthor {
  CLIENT
  STAFF
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  role          UserRole @default(STAFF)
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  createdCustomers Customer[] @relation("customerCreatedBy")
  leads            Lead[]     @relation("leadAssignedUser")
  createdQuotes     Quote[]   @relation("quoteCreatedBy")
  createdOrders     Order[]   @relation("orderCreatedBy")
  loggedPayments    Payment[] @relation("paymentLoggedBy")
  portalStaffMessages OrderPortalMessage[] @relation("PortalMessageStaff")
  portalUploadedPhotos OrderProgressPhoto[] @relation("PortalPhotoUploader")
}

model Customer {
  id                      String   @id @default(cuid())
  fullName                String
  phone                   String?
  email                   String?
  preferredContactChannel String?
  defaultAddress          String?
  notes                   String?
  tagsJson                Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  createdById String?
  createdBy   User? @relation("customerCreatedBy", fields: [createdById], references: [id])

  leads         Lead[]
  conversations Conversation[]
  quotes        Quote[]
  orders        Order[]
  payments      Payment[]
}

model Lead {
  id             String     @id @default(cuid())
  source         String
  externalSourceId String?
  title          String
  description    String?
  status         LeadStatus @default(NEW)
  estimatedValue Decimal?   @db.Decimal(10, 2)
  priority       Int        @default(3)
  lastContactAt  DateTime?
  nextFollowUpAt DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  customerId     String?
  customer       Customer?      @relation(fields: [customerId], references: [id])
  assignedUserId String?
  assignedUser   User?          @relation("leadAssignedUser", fields: [assignedUserId], references: [id])
  conversations  Conversation[]
  quotes         Quote[]
  orders         Order[]
}

model Conversation {
  id                String   @id @default(cuid())
  channel           String
  direction         String
  messageText       String
  externalMessageId String?
  sentAt            DateTime?
  receivedAt        DateTime?
  metadataJson      Json?
  createdAt         DateTime @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  leadId     String?
  lead       Lead?    @relation(fields: [leadId], references: [id])
}

model Quote {
  id          String      @id @default(cuid())
  quoteNumber String      @unique
  status      QuoteStatus @default(DRAFT)
  subtotal    Decimal     @db.Decimal(10, 2)
  tax         Decimal     @default(0) @db.Decimal(10, 2)
  discount    Decimal     @default(0) @db.Decimal(10, 2)
  total       Decimal     @db.Decimal(10, 2)
  expiresAt   DateTime?
  notes       String?
  approvedAt  DateTime?
  declinedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id])
  createdById String?
  createdBy   User?    @relation("quoteCreatedBy", fields: [createdById], references: [id])

  orders Order[]
}

model Order {
  id               String           @id @default(cuid())
  orderNumber      String           @unique
  status           OrderStatus      @default(NEW)
  productionStatus ProductionStatus @default(QUEUED)
  paymentStatus    PaymentStatus    @default(PENDING)
  deliveryStatus   DeliveryStatus?
  dueDate          DateTime?
  subtotal         Decimal          @db.Decimal(10, 2)
  tax              Decimal          @default(0) @db.Decimal(10, 2)
  discount         Decimal          @default(0) @db.Decimal(10, 2)
  total            Decimal          @db.Decimal(10, 2)
  balanceDue       Decimal          @db.Decimal(10, 2)
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id])
  quoteId     String?
  quote       Quote?   @relation(fields: [quoteId], references: [id])
  createdById String?
  createdBy   User?    @relation("orderCreatedBy", fields: [createdById], references: [id])

  items          OrderItem[]
  productionJobs ProductionJob[]
  payments       Payment[]
  deliveries     Delivery[]
  portalMessages OrderPortalMessage[]
  progressPhotos OrderProgressPhoto[]
}

model MagicLinkToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

model OrderPortalMessage {
  id          String               @id @default(cuid())
  orderId     String
  order       Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  body        String
  author      PortalMessageAuthor
  staffUserId String?
  staffUser   User?                @relation("PortalMessageStaff", fields: [staffUserId], references: [id])
  createdAt   DateTime             @default(now())

  @@index([orderId, createdAt])
}

model OrderProgressPhoto {
  id               String   @id @default(cuid())
  orderId          String
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  caption          String?
  mimeType         String
  /// Base64 image (MVP); migrate to object storage for scale.
  imageBase64      String   @db.Text
  uploadedByUserId String?
  uploadedBy       User?    @relation("PortalPhotoUploader", fields: [uploadedByUserId], references: [id])
  visibleToClient  Boolean  @default(true)
  createdAt        DateTime @default(now())

  @@index([orderId, createdAt])
}

model OrderItem {
  id            String   @id @default(cuid())
  itemName      String
  quantity      Int
  unitPrice     Decimal  @db.Decimal(10, 2)
  unitCost      Decimal? @db.Decimal(10, 2)
  materialType  String?
  color         String?
  printSpecJson Json?
  lineTotal     Decimal  @db.Decimal(10, 2)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orderId String
  order   Order @relation(fields: [orderId], references: [id])
}

model ProductionJob {
  id                 String           @id @default(cuid())
  status             ProductionStatus @default(QUEUED)
  queuePosition      Int?
  machineName        String?
  startedAt          DateTime?
  finishedAt         DateTime?
  qualityCheckStatus String?
  failureReason      String?
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])
}

model Payment {
  id            String        @id @default(cuid())
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  referenceCode String?
  paidAt        DateTime
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  loggedById String?
  loggedBy   User?    @relation("paymentLoggedBy", fields: [loggedById], references: [id])
}

model Delivery {
  id            String         @id @default(cuid())
  type          DeliveryType
  status        DeliveryStatus @default(SCHEDULED)
  scheduledAt   DateTime?
  completedAt   DateTime?
  locationText  String?
  recipientName String?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])
}

model MessageTemplate {
  id            String   @id @default(cuid())
  name          String
  category      String
  channel       String
  body          String
  variablesJson Json?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Integration {
  id                    String   @id @default(cuid())
  provider              String
  accountLabel          String
  status                String
  configJsonEncryptedRef String?
  webhookUrl            String?
  lastSyncAt            DateTime?
  lastError             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  syncLogs SyncLog[]

  @@unique([provider, accountLabel])
}

model SyncLog {
  id               String   @id @default(cuid())
  syncType         String
  direction        String
  entityType       String
  entityId         String?
  status           String
  startedAt        DateTime
  endedAt          DateTime?
  recordsProcessed Int      @default(0)
  recordsFailed    Int      @default(0)
  errorDetailsJson Json?
  createdAt        DateTime @default(now())

  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id])

  importRows ImportRow[]
}

model ActivityLog {
  id          String   @id @default(cuid())
  actorUserId String?
  entityType  String
  entityId    String
  action      String
  beforeJson  Json?
  afterJson   Json?
  contextJson Json?
  ipAddress   String?
  createdAt   DateTime @default(now())
}

model Attachment {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  fileName   String
  mimeType   String
  sizeBytes  Int
  storageKey String
  uploadedBy String?
  uploadedAt DateTime @default(now())
}

model Setting {
  id        String   @id @default(cuid())
  scopeType String
  scopeId   String?
  key       String
  valueJson Json
  updatedBy String?
  updatedAt DateTime @updatedAt

  @@unique([scopeType, scopeId, key])
}

model IdempotencyKey {
  id           String   @id @default(cuid())
  scope        String
  key          String
  requestHash  String
  responseJson Json
  statusCode   Int
  createdAt    DateTime @default(now())
  expiresAt    DateTime?

  @@unique([scope, key])
}

model ImportRow {
  id             String   @id @default(cuid())
  syncLogId      String
  rowIndex       Int
  sourceEntityId String?
  rawJson        Json
  mappedJson     Json?
  dedupeKey      String?
  status         String   @default("staged")
  duplicateOfId  String?
  errorMessage   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  syncLog SyncLog @relation(fields: [syncLogId], references: [id])

  @@unique([syncLogId, rowIndex])
  @@index([syncLogId, status])
}
