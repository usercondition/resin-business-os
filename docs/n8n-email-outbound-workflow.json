    {
      "parameters": {
        "jsCode": "/**\n * Body from app: { event, payload }\n */\nconst item = $input.first().json;\nconst event = item.event;\nconst p = item.payload || {};\nif (event === 'email.reply_requested' && !p.toEmail) {\n  throw new Error('Reply requires customer email (payload.toEmail).');\n}\nif (event === 'email.forward_requested' && !p.toEmail) {\n  throw new Error('Forward requires payload.toEmail.');\n}\nreturn [{\n  json: {\n    event,\n    to: p.toEmail,\n    subject: p.subject,\n    text: p.body,\n    payload: p\n  }\n}];"
      },
